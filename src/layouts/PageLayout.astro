---
import BaseLayout from './BaseLayout.astro';
interface Props {
  title?: string;
  frontmatter?: { title?: string };
}
const title = Astro.props.title ?? Astro.props.frontmatter?.title;
---
<BaseLayout title={title ? `${title} - Seotory` : undefined}>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <article class="prose prose-slate prose-blog max-w-none prose-a:text-accent-600">
      <slot />
    </article>
  </div>
</BaseLayout>
