---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';
import AdUnit from '../components/AdUnit.astro';
import { formatDate, excerpt, type Post } from '../utils/posts';

interface Props {
  post: Post;
  related: Post[];
}
const { post, related } = Astro.props;
const { title, date, tags, history } = post.data;
const desc = post.data.description || excerpt(post.body ?? '', 30);
---
<BaseLayout title={title} description={desc} ogType="article">
  <!-- Title header -->
  <header class="bg-accent-600 text-white">
    <div class="mx-auto max-w-3xl px-4 py-20">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">{title}</h1>
      <p class="mt-2 text-white/70">{formatDate(date)}</p>
    </div>
  </header>

  <div class="mx-auto max-w-3xl px-4 py-12">
    {
      history && history.length > 0 && (
        <aside class="mb-8 rounded-xl border border-hairline bg-white p-4 text-sm text-ink-soft">
          <ul class="space-y-1">
            {history.map((d) => (
              <li>
                본 포스팅은 {d.slice(0, 4)}년 {d.slice(4, 6)}월 {d.slice(6, 8)}일에 수정되었습니다.
              </li>
            ))}
          </ul>
        </aside>
      )
    }

    <article class="prose prose-slate prose-blog max-w-none prose-a:text-accent-600">
      <slot />
    </article>

    {
      tags.length > 0 && (
        <div class="mt-10 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-700">
            <Icon name="info" class="size-4" />
            Tags :
          </span>
          {tags.map((tag) => (
            <a
              href={`/tags/#${tag}`}
              class="rounded-lg bg-accent-50 px-2.5 py-1 text-sm font-medium text-accent-700 hover:bg-accent-100"
            >
              {tag.toLowerCase()}
            </a>
          ))}
        </div>
      )
    }

    <AdUnit slot="4825106255" />
  </div>

  {
    related.length > 0 && (
      <section class="mx-auto max-w-4xl px-4 pb-4">
        <h2 class="mb-5 text-lg font-bold tracking-tight">같은 카테고리의 다른 글</h2>
        <div class="grid gap-5 sm:grid-cols-2">
          {related.map((p) => (
            <article class="group flex flex-col rounded-card border border-hairline bg-white p-5 shadow-sm shadow-slate-900/[0.04] transition duration-200 hover:-translate-y-0.5 hover:border-accent-200 hover:shadow-lg hover:shadow-accent-900/10">
              <h3 class="text-lg font-bold tracking-tight">
                <a href={`/post/${p.id}/`} class="text-ink group-hover:text-accent-600">
                  {p.data.title}
                </a>
              </h3>
              <p class="mt-2 line-clamp-3 flex-1 text-sm text-ink-soft">
                {excerpt(p.body ?? '', 30)}
              </p>
              <a
                href={`/post/${p.id}/`}
                class="mt-4 inline-flex justify-center rounded-lg bg-accent-50 px-3 py-2 text-sm font-medium text-accent-700 hover:bg-accent-100"
              >
                더보기
              </a>
            </article>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
