---
import { PAGES_NAV, CATEGORY_NAV } from '../consts';
import Icon from './Icon.astro';
const categoryNav = CATEGORY_NAV.filter((n) => n.use);
---
<nav class="navbar is-transparent">
  <div class="container is-max-widescreen">
    <div class="navbar-brand">
      <a class="navbar-item" href="/">
        <span class="icon"><Icon name="home" /></span>
        <span>SEOTORY</span>
      </a>
      <div class="navbar-burger" data-target="navMenu">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div id="navMenu" class="navbar-menu">
      <div class="navbar-start">
        {PAGES_NAV.map((p) => <a href={p.path} class="navbar-item">{p.title}</a>)}

        {
          categoryNav.map((item) =>
            item.items ? (
              <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link">{item.title}</a>
                <div class="navbar-dropdown">
                  <div class="menu">
                    {item.items
                      .filter((c) => c.use)
                      .map((c) => (
                        <a href={`/categories/${c.path}/`} class="navbar-item">
                          {c.title}
                        </a>
                      ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={`/categories/${item.path}/`} class="navbar-item">
                {item.title}
              </a>
            )
          )
        }
      </div>

      <div class="navbar-end">
        <div class="navbar-item">
          <div class="field is-grouped">
            <div class="field has-addons">
              <div class="control">
                <input
                  class="input is-link is-small is-rounded"
                  type="text"
                  placeholder="Find a repository"
                />
              </div>
              <div class="control">
                <a id="site-search" class="button is-link is-small is-rounded">
                  <span class="icon"><Icon name="search" /></span>
                  <span>Search</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Mobile burger toggle
    document.querySelectorAll<HTMLElement>('.navbar-burger').forEach((burger) => {
      burger.addEventListener('click', () => {
        const target = document.getElementById(burger.dataset.target || '');
        burger.classList.toggle('is-active');
        target?.classList.toggle('is-active');
      });
    });

    // Site-scoped Google search
    const searchBtn = document.getElementById('site-search');
    if (searchBtn) {
      const input = searchBtn
        .closest('.field.has-addons')
        ?.querySelector('input') as HTMLInputElement | null;
      const run = () => {
        const text = (input?.value || '').trim();
        if (!text) return;
        window.open(
          'https://www.google.com/search?q=site:blog.seotory.com+' + encodeURIComponent(text),
          '_blank'
        );
      };
      searchBtn.addEventListener('click', run);
      input?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') run();
      });
    }
  });
</script>
