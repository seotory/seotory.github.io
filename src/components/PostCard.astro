---
import type { Post } from '../utils/posts';
import { excerpt, formatDate } from '../utils/posts';
import Icon from './Icon.astro';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const url = `/post/${post.id}/`;
const desc = post.data.description || excerpt(post.body ?? '', 40);
---
<article
  class="group rounded-card border border-hairline bg-white p-6 shadow-sm shadow-slate-900/[0.04] transition duration-200 hover:-translate-y-0.5 hover:border-accent-200 hover:shadow-lg hover:shadow-accent-900/10"
>
  <h2 class="text-xl font-bold tracking-tight">
    <a href={url} class="text-ink group-hover:text-accent-600">{post.data.title}</a>
  </h2>
  <p class="mt-1 text-sm text-ink-soft">{formatDate(post.data.date)}</p>
  <p class="mt-3 text-ink-soft">{desc}</p>
  {
    post.data.categories && (
      <a
        href={`/categories/${post.data.categories}/`}
        class="mt-4 inline-flex items-center gap-1 rounded-lg bg-accent-50 px-2.5 py-1 text-sm font-medium text-accent-700 hover:bg-accent-100"
      >
        <Icon name="info" class="size-3.5" />
        {post.data.categories}
      </a>
    )
  }
</article>
