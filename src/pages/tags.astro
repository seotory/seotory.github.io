---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, type Post } from '../utils/posts';

const posts = await getPublishedPosts();
const tagMap = new Map<string, Post[]>();
for (const p of posts) {
  for (const t of p.data.tags) {
    if (!tagMap.has(t)) tagMap.set(t, []);
    tagMap.get(t)!.push(p);
  }
}
const tags = [...tagMap.keys()].sort((a, b) => a.localeCompare(b));
---
<BaseLayout title="Tags - Seotory">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-2xl font-bold tracking-tight">Tags</h1>

    <div class="mt-6 flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <a
            href={`#${tag}`}
            class="rounded-lg bg-accent-50 px-2.5 py-1 text-sm font-medium text-accent-700 hover:bg-accent-100"
          >
            {tag} <span class="text-accent-600/60">{tagMap.get(tag)!.length}</span>
          </a>
        ))
      }
    </div>

    <div class="mt-10 space-y-8">
      {
        tags.map((tag) => (
          <section id={tag} class="scroll-mt-20">
            <h2 class="text-lg font-bold tracking-tight text-accent-700">#{tag}</h2>
            <ul class="mt-2 divide-y divide-hairline rounded-card border border-hairline bg-white">
              {tagMap.get(tag)!.map((post) => (
                <li>
                  <a href={`/post/${post.id}/`} class="block px-5 py-3 hover:bg-accent-50">
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
