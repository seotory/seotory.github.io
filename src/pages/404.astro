---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 - Seotory">
  <div class="mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center">
    <p class="text-6xl font-extrabold tracking-tight text-accent-600">404</p>
    <p class="mt-4 text-lg text-ink-soft">페이지를 찾을 수 없습니다.</p>
    <a
      href="/"
      class="mt-8 inline-flex rounded-lg bg-accent-600 px-4 py-2.5 font-medium text-white hover:bg-accent-700"
    >
      홈으로
    </a>
  </div>
</BaseLayout>
