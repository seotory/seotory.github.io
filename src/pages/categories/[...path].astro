---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getPublishedPosts,
  postsInCategory,
  categoryKeys,
  formatDate,
} from '../../utils/posts';
import { CATEGORY_NAV } from '../../consts';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const keys = new Set<string>();
  // Keys from actual posts…
  posts.forEach((p) => categoryKeys(p.data.categories).forEach((k) => keys.add(k)));
  // …plus every nav category, so linked-but-empty pages (e.g. Talk) still exist.
  CATEGORY_NAV.forEach((item) => {
    if (item.path) keys.add(item.path);
    item.items?.forEach((c) => c.path && keys.add(c.path));
  });
  return [...keys].map((key) => ({
    params: { path: key },
    props: { key, posts: postsInCategory(posts, key) },
  }));
}) satisfies GetStaticPaths;

const { key, posts } = Astro.props;
---
<BaseLayout title={`${key} - Seotory`}>
  <section class="page-content section">
    <div class="container is-max-widescreen">
      <header class="list-header">
        <h1 class="title is-4">{key} - {posts.length}건</h1>
      </header>
      <ul>
        {
          posts.map((post) => (
            <li>
              <a href={`/post/${post.id}/`}>{post.data.title}</a>{' '}
              <span class="list-post-time">[{formatDate(post.data.date)}]</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
