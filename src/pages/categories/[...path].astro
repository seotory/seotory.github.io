---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getPublishedPosts,
  postsInCategory,
  categoryKeys,
  formatDate,
} from '../../utils/posts';
import { CATEGORY_NAV } from '../../consts';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const keys = new Set<string>();
  // Keys from actual posts…
  posts.forEach((p) => categoryKeys(p.data.category).forEach((k) => keys.add(k)));
  // …plus every nav category, so a linked-but-empty page still exists.
  CATEGORY_NAV.forEach((item) => {
    keys.add(item.path);
    item.items?.forEach((c) => keys.add(c.path));
  });
  return [...keys].map((key) => ({
    params: { path: key },
    props: { key, posts: postsInCategory(posts, key) },
  }));
}) satisfies GetStaticPaths;

const { key, posts } = Astro.props;
---
<BaseLayout title={`${key} - Seotory`}>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-2xl font-bold tracking-tight">
      {key}
      <span class="ml-1 text-base font-normal text-ink-soft">{posts.length}건</span>
    </h1>

    {
      posts.length === 0 ? (
        <p class="mt-6 text-ink-soft">아직 글이 없습니다.</p>
      ) : (
        <ul class="mt-6 divide-y divide-hairline overflow-hidden rounded-card border border-hairline bg-white">
          {posts.map((post) => (
            <li>
              <a
                href={`/post/${post.id}/`}
                class="flex items-baseline justify-between gap-4 px-5 py-3.5 hover:bg-accent-50"
              >
                <span class="font-medium text-ink">{post.data.title}</span>
                <span class="shrink-0 text-sm text-ink-soft">{formatDate(post.data.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
